{
  "name": "ap-guitar-webapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AP Guitar - Vite + TypeScript webapp for Storm Studios.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5175",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5175",
    "test": "vitest run",
    "check": "npm run test && npm run build",
    "sync:assets": "node scripts/sync-assets.mjs",
    "deploy": "npm run build && node scripts/copy-dist.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
